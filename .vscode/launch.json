{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug STM32F103C8 (CMSIS-DAP)",
      "type": "cortex-debug",
      "request": "launch",
      "servertype": "openocd",
      "cwd": "${workspaceRoot}",
      "executable": "build/STM32F103C8_FreeRTOS.elf",
      "device": "STM32F103C8",
      "interface": "swd",
      "runToEntryPoint": "main",
      "configFiles": [
        "interface/cmsis-dap.cfg",
        "target/stm32f1x.cfg"
      ],
      "preLaunchTask": "Build",
      // "svdFile": "${workspaceRoot}/STM32F103.svd",  // 可选，若你有 .svd 文件
      "showDevDebugOutput": "none"
    }
  ]
}